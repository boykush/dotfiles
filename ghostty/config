theme = nord
font-family = Hack Nerd Font Mono
# Osaka は近年のmacOSから削除されたため、標準同梱の Hiragino Sans に変更。
# 単に "Hiragino Sans" だと最も細い W1 が選ばれて細く・グレーに見えるため、
# 読みやすい太さの W4 を明示指定する（W3=普通〜W6=中太の範囲で好みに調整可）。
font-family = Hiragino Sans W4

macos-titlebar-style = tabs
macos-option-as-alt = true

window-padding-x = 16
window-padding-y = 8

copy-on-select = clipboard

keybind = super+alt+h=goto_split:left
keybind = super+alt+j=goto_split:down
keybind = super+alt+k=goto_split:up
keybind = super+alt+l=goto_split:right

# tmux内でShift+Enterを動作させるためのワークアラウンド
keybind = shift+enter=text:\x1b\r
