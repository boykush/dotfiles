#!/bin/bash
#MISE description="Add a worker pane to claude-tasks session"

SESSION_NAME="claude-tasks"
WINDOW_NAME="tasks"

TARGET_DIR="${1:?Usage: mise run claude:tmux-tasks:add <directory> [worktree-name] [task-id]}"
WORKTREE_NAME="${2:-}"
TASK_ID="${3:-}"

# Resolve to absolute path
TARGET_DIR=$(cd "$TARGET_DIR" 2>/dev/null && pwd) || { echo "Directory not found: $1"; exit 1; }
REPO_NAME=$(basename "$TARGET_DIR")

if [ -n "$WORKTREE_NAME" ]; then
    WORKER_NAME="${REPO_NAME}-${WORKTREE_NAME}"
else
    WORKER_NAME="$REPO_NAME"
fi

if ! tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    echo "Session '$SESSION_NAME' not found. Run 'mise run claude:tmux-tasks' first."
    exit 1
fi

# Check if worker already exists by pane title
if tmux list-panes -t "$SESSION_NAME:$WINDOW_NAME" -F '#{pane_title}' | grep -q "^${WORKER_NAME}$"; then
    echo "Worker '$WORKER_NAME' already exists."
    exit 0
fi

TMUX_CMD="mise exec -- claude --settings ~/.claude/claude-tasks.json --dangerously-skip-permissions"

if [ -n "$WORKTREE_NAME" ]; then
    TMUX_CMD="$TMUX_CMD --worktree $WORKTREE_NAME"
else
    TMUX_CMD="$TMUX_CMD --worktree"
fi

if [ -n "$TASK_ID" ]; then
    TMUX_CMD="$TMUX_CMD --append-system-prompt 'あなたはタスク #${TASK_ID} に割り当てられたワーカーです。'"
    TMUX_CMD="$TMUX_CMD 'TaskGet #${TASK_ID} で割り当てられたタスクの詳細を確認し、着手してください'"
fi

# First worker: split horizontally (create right column)
# Subsequent workers: split last right pane vertically (stack)
PANE_COUNT=$(tmux list-panes -t "$SESSION_NAME:$WINDOW_NAME" | wc -l | tr -d ' ')

if [ "$PANE_COUNT" -eq 1 ]; then
    tmux split-window -h -t "$SESSION_NAME:$WINDOW_NAME.0" -c "$TARGET_DIR" \
        -e CLAUDE_CODE_TASK_LIST_ID="$SESSION_NAME" \
        "$TMUX_CMD"
else
    LAST_PANE=$(tmux list-panes -t "$SESSION_NAME:$WINDOW_NAME" -F '#{pane_index}' | tail -1)
    tmux split-window -v -t "$SESSION_NAME:$WINDOW_NAME.${LAST_PANE}" -c "$TARGET_DIR" \
        -e CLAUDE_CODE_TASK_LIST_ID="$SESSION_NAME" \
        "$TMUX_CMD"
fi

# Set pane title for identification
NEW_PANE=$(tmux list-panes -t "$SESSION_NAME:$WINDOW_NAME" -F '#{pane_index}' | tail -1)
tmux select-pane -t "$SESSION_NAME:$WINDOW_NAME.${NEW_PANE}" -T "$WORKER_NAME"

# Return focus to management pane
tmux select-pane -t "$SESSION_NAME:$WINDOW_NAME.0"
