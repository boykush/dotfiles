#!/bin/bash
#MISE description="Remove a worker pane from claude-tasks session"

SESSION_NAME="claude-tasks"
WINDOW_NAME="tasks"
WORKER_NAME="${1:?Usage: mise run claude:tmux-tasks:remove <worker-name>}"

if ! tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    echo "Session '$SESSION_NAME' not found."
    exit 1
fi

# Find the pane by title
PANE_ID=$(tmux list-panes -t "$SESSION_NAME:$WINDOW_NAME" -F '#{pane_index} #{pane_title}' \
    | awk -v name="$WORKER_NAME" '$0 ~ " "name"$" {print $1}')

if [ -z "$PANE_ID" ]; then
    echo "Worker '$WORKER_NAME' not found."
    echo "Active workers:"
    tmux list-panes -t "$SESSION_NAME:$WINDOW_NAME" -F '  #{pane_title}' | tail -n +2
    exit 1
fi

tmux kill-pane -t "$SESSION_NAME:$WINDOW_NAME.${PANE_ID}"
