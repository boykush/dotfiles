#!/bin/bash
#MISE description="Start tmux with Claude Code in a worktree (parallel work)"
#MISE dir="{{cwd}}"

SESSION_NAME="claude-dev"

# Select repository directory via zoxide
TARGET_DIR=$(zoxide query -i) || exit 0
REPO_NAME=$(basename "$TARGET_DIR")

# Auto-generate sequential worktree number
NEXT_NUM=1
if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    LAST_NUM=$(tmux list-windows -t "$SESSION_NAME" -F '#{window_name}' | sed -n "s/^${REPO_NAME}-wt\([0-9]*\)$/\1/p" | sort -n | tail -1)
    [ -n "$LAST_NUM" ] && NEXT_NUM=$((LAST_NUM + 1))
fi
WORKTREE_NAME="wt${NEXT_NUM}"

WINDOW_NAME="${REPO_NAME}-${WORKTREE_NAME}"
CLAUDE_CMD="mise exec -- claude --settings ~/.claude/claude-dev-wt.json --teammate-mode in-process --worktree $WORKTREE_NAME"

if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    if tmux list-windows -t "$SESSION_NAME" -F '#{window_name}' | grep -q "^${WINDOW_NAME}$"; then
        tmux select-window -t "$SESSION_NAME:$WINDOW_NAME"
    else
        tmux new-window -t "$SESSION_NAME" -n "$WINDOW_NAME" -c "$TARGET_DIR" "$CLAUDE_CMD"
    fi
    [ -z "$TMUX" ] && tmux attach-session -t "$SESSION_NAME"
else
    tmux new-session -d -s "$SESSION_NAME" -n "$WINDOW_NAME" -c "$TARGET_DIR" "$CLAUDE_CMD"
    tmux attach-session -t "$SESSION_NAME"
fi
