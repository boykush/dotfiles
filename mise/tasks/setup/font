#!/bin/bash
#MISE description="Hack Nerd Font を ~/Library/Fonts に導入（ghostty 主フォント）"
#MISE dir="{{cwd}}"
set -euo pipefail

# ghostty/config が主フォントに使う Hack Nerd Font（Mono）を導入する。brew(cask) 卒業に伴い
# フォントは mise task で管理する。フォントは実行ファイルではなく ~/Library/Fonts に置いて OS に
# 認識させる必要があり、mise [tools] の各 backend（PATH にバイナリを通す仕組み）では扱えない
# ため task 化している。version は renovate 追従外なので更新時は手動で bump する
# （最新は https://github.com/ryanoasis/nerd-fonts/releases）。
VERSION="v3.4.0"
FONT="Hack"
DEST="${HOME}/Library/Fonts"

# 冪等: 既に Mono が入っていれば何もしない。
# 全角括弧の直後に変数を置くため ${var} で明示区切りする（非 UTF-8 locale での誤スキャン回避）。
if ls "${DEST}"/HackNerdFontMono-*.ttf >/dev/null 2>&1; then
  echo "[INFO] ${FONT} Nerd Font は導入済み（${DEST}）"
  exit 0
fi

tmp="$(mktemp -d)"
trap 'rm -rf "${tmp}"' EXIT

echo "[INFO] ${FONT} Nerd Font ${VERSION} を取得中…"
# -f: HTTP エラーで失敗させる（set -e で中断）。macOS の tar は xz を自動判定。
curl -fsSL -o "${tmp}/${FONT}.tar.xz" \
  "https://github.com/ryanoasis/nerd-fonts/releases/download/${VERSION}/${FONT}.tar.xz"
tar -xf "${tmp}/${FONT}.tar.xz" -C "${tmp}"

count="$(find "${tmp}" -name '*.ttf' | wc -l | tr -d ' ')"
if [ "${count}" -eq 0 ]; then
  echo "[ERROR] .ttf が見つかりません（アーカイブ構造が変わった可能性）" >&2
  exit 1
fi

mkdir -p "${DEST}"
find "${tmp}" -name '*.ttf' -exec cp {} "${DEST}/" \;
echo "[INFO] ${FONT} Nerd Font を ${DEST} に導入しました（${count} ファイル）"
